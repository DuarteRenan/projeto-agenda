<%- include ('includes/head') %>
<%- include ('includes/nav') %>


 <div class="container">
  <div class="row">
    <div class="col-lg-2"></div>

    <div class="col-lg-8 my-4">
      <h1 class=" text-center">
        Agenda
      </h1>
      <p class="lead text-center">
        Seus contatos estão abaixo
      </p>


      <%- include('includes/messages') %>
    
      <% if (contatos.length > 0) { %>
      <div class="responsive-rable">
        <table class="table my-2">
          <% contatos.forEach(contato => { %>
            <tr>
            <td class="py-3"><%= contato.nome %></td>
            <td class="py-3"><%= contato.sobrenome %></td>
            <td class="py-3"><%= contato.telefone %></td>
            <td class="py-3"><%= contato.email %></td>
            <td class="py-3"><a href="/contato/index/<%= contato._id %>">Editar</td>
            <td class="py-3"><a class="text-danger" href="/contato/delete/<%= contato._id %>">Excluir</td>
          </tr>
          <%  }); %>
         
        </table>
      </div>
      <% } else { %>
         <p class="lead text-center">
        Agenda vazia
      </p>
      <% } %>
    </div>

    <div class="col-lg-2"></div>
  </div>
 </div>


 <%- include ('includes/footer') %>